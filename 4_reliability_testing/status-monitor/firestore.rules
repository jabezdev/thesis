rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /readings/{documentId} {
      allow read, write: if true;
    }

    match /heartbeats/{documentId} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}