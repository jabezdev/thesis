# Dokploy / docker compose environment variables template

# Core runtime
PORT=3000
FRONTEND_PORT=18080
POLL_INTERVAL_MS=15000
STATION_ID=reliability_station_1
SQLITE_PATH=/data/reliability.db

# Firebase
FIREBASE_PROJECT_ID=panahon-live
FIREBASE_API_KEY=PASTE_FIREBASE_API_KEY_HERE

# Auth and session
AUTH_USERNAME=researcher
AUTH_PASSWORD=PASTE_STRONG_PASSWORD_HERE
SESSION_SECRET=PASTE_LONG_RANDOM_SECRET_HERE
SESSION_TTL_SEC=43200
COOKIE_SECURE=true

# Anomaly tuning
EXPECTED_PACKET_INTERVAL_SEC=60
PACKET_TOLERANCE_SEC=25
MAX_CSV_ROWS=50000
