# Firebase project
FIREBASE_PROJECT_ID=panahon-live
FIREBASE_DATABASE_URL=https://panahon-live-default-rtdb.firebaseio.com

# Service account — base64-encoded JSON
# Generate with: base64 -w 0 firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON_

# Firestore collection name (default: readings)
FIRESTORE_READINGS_COLLECTION=readings
